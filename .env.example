# 飞书多维表格配置
FEISHU_APP_ID=cli_xxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BITABLE_TOKEN=xxxxxxxxxx

# 魔搭 API 配置（用于图片生成）
MODEL_SCOPE_API_TOKEN=ms_xxxxxxxxxxxxxxxxxxxxx

# 启用飞书存储（设置为 true 启用，false 或不设置则使用本地存储）
USE_FEISHU_STORAGE=false

# JWT 密钥（建议修改为更安全的密钥）
JWT_SECRET=your-secret-key

# 服务器端口
PORT=3000